# LLM для генерации ответов
# Вариант 1: OpenAI-compatible API (llama.cpp/qwen)
LLM_MAIN_TYPE=openai
LLM_MAIN_URL=https://qwen.cyberden.ru/v1
LLM_MAIN_MODEL=qwen2.5:3b
LLM_MAIN_KEY=your-token-here

# Вариант 2: Gemini API (быстрее, но требует API ключ)
# LLM_MAIN_TYPE=gemini
# LLM_MAIN_URL=  # не нужен для Gemini
# LLM_MAIN_MODEL=gemini-2.0-flash-exp
# LLM_MAIN_KEY=your-gemini-api-key

# LLM для embeddings (всегда OpenAI-compatible)
LLM_EMBED_TYPE=openai
LLM_EMBED_URL=https://bge-m3.cyberden.ru/v1
LLM_EMBED_MODEL=bge-m3
LLM_EMBED_KEY=your-embed-token-here

# Параметры chunking
CHUNK_METHOD=markdown
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Параметры векторного поиска
TOP_K=5
MIN_SIMILARITY=0.6

# Параметры LLM (gemma3)
MAX_TOKENS=2000
TEMPERATURE=0.3
MAX_PROMPT_CHARS=24000

# Параметры параллельной обработки
MAX_CONCURRENCY=2

# Директория для данных (опционально)
DATA_DIR=./data